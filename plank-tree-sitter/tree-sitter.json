{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "plank",
      "camelcase": "Plank",
      "title": "Plank",
      "scope": "source.plank",
      "file-types": [
        "plank"
      ],
      "injection-regex": "^plank$",
      "class-name": "TreeSitterPlank"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Plank grammar for tree-sitter",
    "authors": [
      {
        "name": "philogy"
      }
    ],
    "links": {
      "repository": "https://github.com/plankevm/plank-monorepo"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": true
  }
}
