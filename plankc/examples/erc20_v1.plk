const dangling = fn() memptr { @malloc_uninit(0) };

const revert_empty = fn() never {
    @evm_revert(dangling(), 0);
};

const addr = struct { raw: u256 };

const to_addr = fn (raw: u256) addr {
    if @evm_gt(@evm_shr(160, raw), 0) {
        revert_empty();
    }
    addr { raw: raw }
};

const get_balance_slot = fn (owner: addr) u256 {
    let buf = @malloc_uninit(32);
    @mstore32(buf, owner.raw);
    @evm_keccak256(buf, 32)
};

init {
    let constructor_args = @malloc_uninit(64);
    @evm_codecopy(constructor_args, @init_end_offset(), 64);

    let owner = to_addr(@mload32(constructor_args));
    let amount = @mload32(@evm_add(constructor_args, 32));

    let bal_slot = get_balance_slot(owner);
    @evm_sstore(bal_slot, amount);

    // Return runtime.
    let runtime: memptr = @malloc_uninit(@runtime_length());
    @evm_codecopy(runtime, @runtime_start_offset(), @runtime_length());
    @evm_return(runtime, @runtime_length());
}

const BALANCE_OF_SELECTOR = 0x70a08231;
const TRANSFER_SELECTOR = 0xa9059cbb;

run {
    let selector = @evm_shr(@evm_sub(256, 32), @evm_calldataload(0));

    if @evm_eq(selector, TRANSFER_SELECTOR) {
        let to: addr = to_addr(@evm_calldataload(0x04));
        let amount: u256 = @evm_calldataload(0x24);

        let from_balance_slot = get_balance_slot(addr { raw: @evm_caller() });
        let from_balance = @evm_sload(from_balance_slot);
        if @evm_lt(from_balance, amount) {
            revert_empty();
        }
        @evm_sstore(from_balance_slot, @evm_sub(from_balance, amount));

        let to_balance_slot = get_balance_slot(to);
        let to_balance = @evm_sload(to_balance_slot);
        @evm_sstore(to_balance_slot, @evm_add(to_balance, amount));

        @evm_stop();
    } else if @evm_eq(selector, BALANCE_OF_SELECTOR) {
        let owner: addr = to_addr(@evm_calldataload(0x04));
        let bal_slot = get_balance_slot(owner);
        let bal = @evm_sload(bal_slot);

        let ret_buf = @malloc_uninit(32);
        @mstore32(ret_buf, bal);
        @evm_return(ret_buf, 32);
    } else {
        revert_empty();
    }
}
