// Reproduces an old codegen bug in the assembler that arises from overly strict arithmetic.
fn init:
    b0 {
        => @b1
    }
    b1 {
        => @b2
    }
    b2 {
        => @b3
    }
    b3 {
        => @b4
    }
    b4 {
        => @b5
    }
    b5 {
        => @b6
    }
    b6 {
        => @b7
    }
    b7 {
        => @b8
    }
    b8 {
        => @b9
    }
    b9 {
        => @b10
    }
    b10 {
        => @b11
    }
    b11 {
        => @b12
    }
    b12 {
        => @b13
    }
    b13 {
        => @b14
    }
    b14 {
        => @b15
    }
    b15 {
        => @b16
    }
    b16 {
        => @b17
    }
    b17 {
        => @b18
    }
    b18 {
        => @b19
    }
    b19 {
        => @b20
    }
    b20 {
        => @b21
    }
    b21 {
        => @b22
    }
    b22 {
        => @b23
    }
    b23 {
        => @b24
    }
    b24 {
        => @b25
    }
    b25 {
        => @b26
    }
    b26 {
        => @b27
    }
    b27 {
        => @b28
    }
    b28 {
        => @b29
    }
    b29 {
        => @b30
    }
    b30 {
        => @b31
    }
    b31 {
        => @b32
    }
    b32 {
        => @b33
    }
    b33 {
        => @b34
    }
    b34 {
        => @b35
    }
    b35 {
        => @b36
    }
    b36 {
        => @b37
    }
    b37 {
        => @b38
    }
    b38 {
        => @b39
    }
    b39 {
        => @b40
    }
    b40 {
        => @b41
    }
    b41 {
        => @b42
    }
    b42 {
        => @b43
    }
    b43 {
        => @b44
    }
    b44 {
        => @b45
    }
    b45 {
        => @b46
    }
    b46 {
        => @b47
    }
    b47 {
        => @b48
    }
    b48 {
        => @b49
    }
    b49 {
        => @b50
    }
    b50 {
        runtime_off = runtime_start_offset
        runtime_len = runtime_length
        buf = malloc runtime_len
        codecopy buf runtime_off runtime_len
        return buf runtime_len
    }

fn main:
    entry {
        => @other
    }
    other {
        stop
    }
