import std::storage::{map_slot_hash, sstore_bytes, sload_bytes, slot_hash};
import std::abi::{abi_encode, abi_decode};
import std::membytes::{membytes, membytes_from_ptr};
import std::constructor::return_runtime;

// Arrays are not yet supported, so we hardcode 3 owners with a 2-of-3 threshold.
const THRESHOLD = 2;
const OWNER0_SLOT = 0;
const OWNER1_SLOT = 1;
const OWNER2_SLOT = 2;
const TX_COUNT_SLOT = 3;
const CONFIRMATIONS_BASE_SLOT = 4;

const ConstructorArgs = struct {
    owner0: u256,
    owner1: u256,
    owner2: u256,
};

const SubmitArgs = struct {
    to: u256,
    value: u256,
    data: membytes,
};

const GetTxResult = struct {
    to: u256,
    value: u256,
    data: membytes,
    executed: u256,
};

const SUBMIT_SELECTOR = 0xc6427474;
const CONFIRM_SELECTOR = 0xc01a8c84;
const EXECUTE_SELECTOR = 0xee22610b;
const REVOKE_SELECTOR = 0x20ea8d86;
const GET_CONF_COUNT_SELECTOR = 0x8b51d13f;
const GET_TX_SELECTOR = 0x33ea3dc8;

const SUBMIT_TOPIC = 0x08324b3d745b914e3abd4ffbfead91e3b78391a98c173202129215ab933adfbe;
const CONFIRM_TOPIC = 0xbde73c39e691e6143456e01935275fd9f654dacca25911f03ab0d587644377eb;
const REVOKE_TOPIC = 0xec9ab91322523c899ede7830ec9bfc992b5981cdcc27b91162fb23de5791117b;
const EXECUTE_TOPIC = 0xddb556f1d2c1ec821e910b019d3685b229db152a0ecd517ca7e24b8bd7139289;

init {
    let args_buf = @malloc_zeroed(96);
    @evm_codecopy(args_buf, @init_end_offset(), 96);
    let constructor_args = abi_decode(ConstructorArgs, membytes_from_ptr(args_buf, 96));
    @evm_sstore(OWNER0_SLOT, constructor_args.owner0);
    @evm_sstore(OWNER1_SLOT, constructor_args.owner1);
    @evm_sstore(OWNER2_SLOT, constructor_args.owner2);

    return_runtime();
}

run {
    let selector = @evm_calldataload(0) >> 224;
    if selector == SUBMIT_SELECTOR {
        submit();
    } else if selector == CONFIRM_SELECTOR {
        confirm();
    } else if selector == EXECUTE_SELECTOR {
        execute();
    } else if selector == REVOKE_SELECTOR {
        revoke();
    } else if selector == GET_CONF_COUNT_SELECTOR {
        get_conf_count();
    } else if selector == GET_TX_SELECTOR {
        get_tx();
    } else {
        @evm_revert(@malloc_uninit(0), 0);
    } 
}

const submit = fn () never {
    let caller = @evm_caller();
    if !is_owner(caller) {
        @evm_revert(@malloc_uninit(0), 0);
    }
    let tx_id = @evm_sload(TX_COUNT_SLOT);
    let tx_base_slot = slot_hash(TX_COUNT_SLOT) +% tx_id * 4;

    let cd_size = @evm_calldatasize() - 4;
    let buf = @malloc_uninit(cd_size);
    @evm_calldatacopy(buf, 4, cd_size);
    let args = abi_decode(SubmitArgs, membytes_from_ptr(buf, cd_size));

    @evm_sstore(tx_base_slot, args.to);
    @evm_sstore(tx_base_slot +% 1, args.value);
    sstore_bytes(tx_base_slot +% 2, args.data);
    @evm_sstore(tx_base_slot +% 3, 0);

    @evm_sstore(TX_COUNT_SLOT, tx_id + 1);
    @evm_log2(@malloc_uninit(0), 0, SUBMIT_TOPIC, tx_id);
    let ret = @malloc_uninit(32);
    @mstore32(ret, tx_id);
    @evm_return(ret, 32);
};

const confirm = fn () never {
    set_confirmation(1, CONFIRM_TOPIC);
};

const execute = fn () never {
    let caller = @evm_caller();
    if !is_owner(caller) {
        @evm_revert(@malloc_uninit(0), 0);
    }

    let tx_id = @evm_calldataload(4);
    let confs = count_confirmations(tx_id);
    if confs < THRESHOLD {
        @evm_revert(@malloc_uninit(0), 0);
    }

    let tx_base_slot = slot_hash(TX_COUNT_SLOT) +% tx_id * 4;
    let executed = @evm_sload(tx_base_slot +% 3);
    if executed != 0 {
        @evm_revert(@malloc_uninit(0), 0);
    }

    @evm_sstore(tx_base_slot +% 3, 1);

    let to = @evm_sload(tx_base_slot);
    let value = @evm_sload(tx_base_slot +% 1);
    let data = sload_bytes(tx_base_slot +% 2);
    let success = @evm_call(@evm_gas(), to, value, data.ptr, data.len, @malloc_uninit(0), 0);
    if !success {
        @evm_revert(@malloc_uninit(0), 0);
    }

    @evm_log2(@malloc_uninit(0), 0, EXECUTE_TOPIC, tx_id);
    @evm_return(@malloc_uninit(0), 0);
};

const revoke = fn () never {
    set_confirmation(0, REVOKE_TOPIC);
};

const get_conf_count = fn () never {
    let tx_id = @evm_calldataload(4);
    let confs = count_confirmations(tx_id);
    let buf = @malloc_uninit(32);
    @mstore32(buf, confs);
    @evm_return(buf, 32);
};

const get_tx = fn () never {
    let tx_id = @evm_calldataload(4);
    let tx_base_slot = slot_hash(TX_COUNT_SLOT) +% tx_id * 4;

    let tx_result = GetTxResult {
        to: @evm_sload(tx_base_slot),
        value: @evm_sload(tx_base_slot +% 1),
        data: sload_bytes(tx_base_slot +% 2),
        executed: @evm_sload(tx_base_slot +% 3)
    };

    let encoded = abi_encode(GetTxResult, tx_result);
    @evm_return(encoded.ptr, encoded.len);
};

const is_owner = fn (caller: u256) bool {
    if caller == @evm_sload(OWNER0_SLOT) {
        true
    } else if caller == @evm_sload(OWNER1_SLOT) {
        true
    } else if caller == @evm_sload(OWNER2_SLOT) {
        true
    } else {
        false
    }
};

const conf_of = fn (owner: u256, tx_id: u256) u256 {
    let conf_slot = map_slot_hash(owner, map_slot_hash(tx_id, CONFIRMATIONS_BASE_SLOT));
    @evm_sload(conf_slot)
};

const set_confirmation = fn (comptime value: u256, comptime topic: u256) never {
    let tx_id = @evm_calldataload(4);
    let tx_count = @evm_sload(TX_COUNT_SLOT);
    if tx_id >= tx_count {
        @evm_revert(@malloc_uninit(0), 0);
    }

    let caller = @evm_caller();
    if !is_owner(caller) {
        @evm_revert(@malloc_uninit(0), 0); 
    }

    let conf_slot = map_slot_hash(caller, map_slot_hash(tx_id, CONFIRMATIONS_BASE_SLOT));
    let conf = @evm_sload(conf_slot);
    if conf != 1 - value {
        @evm_revert(@malloc_uninit(0), 0);
    }

    @evm_sstore(conf_slot, value);
    @evm_log3(@malloc_uninit(0), 0, topic, caller, tx_id);
    @evm_return(@malloc_uninit(0), 0);
};

const count_confirmations = fn (tx_id: u256) u256 {
    let mut confs = 0;
    confs = confs + conf_of(@evm_sload(OWNER0_SLOT), tx_id);
    confs = confs + conf_of(@evm_sload(OWNER1_SLOT), tx_id);
    confs = confs + conf_of(@evm_sload(OWNER2_SLOT), tx_id);
    confs
};
