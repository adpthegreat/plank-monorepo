import std::abi::{abi_encode, abi_decode, abi_encoded_size};
import std::membytes::{membytes, membytes_from_ptr};

const Level0 = struct { x: u256, data: membytes };
const Level1 = struct { inner: Level0, flag: bool };
const Level2 = struct { inner: Level1, y: u256, suffix: membytes };

init {
    let size = @evm_calldatasize();
    let ptr = @malloc_zeroed(size);
    @evm_calldatacopy(ptr, 0, size);
    let buf = membytes_from_ptr(ptr, size);
    let decoded = abi_decode(Level2, buf);
    let esize = abi_encoded_size(Level2, decoded);
    let encoded = abi_encode(Level2, decoded);
    let out_ptr = @malloc_zeroed(@evm_add(32, encoded.len));
    @mstore32(out_ptr, esize);
    @mcopy(@evm_add(out_ptr, 32), encoded.ptr, encoded.len);
    @evm_return(out_ptr, @evm_add(32, encoded.len));
}
