#!/usr/bin/env bash
set -euo pipefail

PLANK_DIR="${PLANK_DIR:-$HOME/.plank}"
PLANK_BIN_DIR="$PLANK_DIR/bin"
PLANK_DOC_DIR="$PLANK_DIR/share/doc"

REPO="plankevm/plank-monorepo"
GITHUB_API="https://api.github.com/repos/$REPO/releases"
GITHUB_DOWNLOAD="https://github.com/$REPO/releases/download"

TMPDIR_CLEANUP=""

say() { printf "plankup: %s\n" "$1"; }
warn() { say "warning: $1" >&2; }
err() { say "error: $1" >&2; exit 1; }

need_cmd() {
    if ! command -v "$1" > /dev/null 2>&1; then
        err "need '$1' (command not found)"
    fi
}

download() {
    local url="$1"
    local output="$2"
    curl -sSfL "$url" -o "$output" || err "failed to download $url"
}

detect_platform() {
    local uname_s
    uname_s=$(uname -s)
    case "$uname_s" in
        Linux*)  PLATFORM="linux" ;;
        Darwin*) PLATFORM="darwin" ;;
        *)       err "unsupported platform: $uname_s" ;;
    esac
}

detect_arch() {
    local uname_m
    uname_m=$(uname -m)
    case "$uname_m" in
        x86_64)
            # Check for Rosetta translation on macOS
            if [ "$(sysctl -n sysctl.proc_translated 2>/dev/null || echo 0)" = "1" ]; then
                ARCH="arm64"
            else
                ARCH="amd64"
            fi
            ;;
        arm64|aarch64)
            ARCH="arm64"
            ;;
        *)
            err "unsupported architecture: $uname_m"
            ;;
    esac
}

compute_sha256() {
    local file="$1"
    if command -v sha256sum > /dev/null 2>&1; then
        sha256sum "$file" | awk '{print $1}'
    elif command -v shasum > /dev/null 2>&1; then
        shasum -a 256 "$file" | awk '{print $1}'
    else
        return 1
    fi
}

verify_checksum() {
    local file="$1"
    local checksums_file="$2"
    local filename
    filename=$(basename "$file")

    local expected
    expected=$(grep "$filename" "$checksums_file" | awk '{print $1}')
    if [ -z "$expected" ]; then
        err "no checksum found for $filename in checksums.txt"
    fi

    local actual
    if ! actual=$(compute_sha256 "$file"); then
        warn "could not verify checksum — neither 'sha256sum' nor 'shasum' found"
        printf "continue without verification? [y/N] "
        read -r answer
        if [ "$answer" != "y" ] && [ "$answer" != "Y" ]; then
            err "aborted"
        fi
        return
    fi

    if [ "$actual" != "$expected" ]; then
        err "checksum mismatch for $filename\n  expected: $expected\n  actual:   $actual"
    fi

    say "checksum verified for $filename"
}

resolve_latest_version() {
    need_cmd curl

    local response
    response=$(curl -sSfL "$GITHUB_API/latest" 2>/dev/null) \
        || err "failed to fetch latest release from GitHub API. Check your internet connection."

    LATEST_TAG=$(echo "$response" | grep '"tag_name"' | sed 's/.*"tag_name": *"\([^"]*\)".*/\1/')
    if [ -z "$LATEST_TAG" ]; then
        err "could not determine latest release tag"
    fi
}

usage() {
    cat <<EOF
plankup — the Plank compiler installer and updater

USAGE:
    plankup
    plankup -h | --help

Running plankup without arguments installs the latest version of plank.
EOF
}

main() {
    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)
                usage
                return
                ;;
            *)
                err "unknown argument: $1"
                ;;
        esac
        shift
    done

    need_cmd curl
    need_cmd tar
    need_cmd mkdir

    detect_platform
    detect_arch

    say "fetching latest release..."
    resolve_latest_version
    local version="$LATEST_TAG"

    say "installing plank $version ($PLATFORM/$ARCH)..."

    # Set up temp directory for download
    local tmpdir
    tmpdir=$(mktemp -d)
    TMPDIR_CLEANUP="$tmpdir"
    trap 'rm -rf "$TMPDIR_CLEANUP"' EXIT

    local asset_name="plank-${version}-${PLATFORM}-${ARCH}.tar.gz"
    local download_url="$GITHUB_DOWNLOAD/$version/$asset_name"
    local checksums_url="$GITHUB_DOWNLOAD/$version/checksums.txt"

    # Download checksums and tarball
    say "downloading checksums..."
    download "$checksums_url" "$tmpdir/checksums.txt"

    say "downloading $asset_name..."
    download "$download_url" "$tmpdir/$asset_name"

    # Verify checksum
    verify_checksum "$tmpdir/$asset_name" "$tmpdir/checksums.txt"

    # Extract to temp, then move binary into place
    tar -xzf "$tmpdir/$asset_name" -C "$tmpdir"

    if [ ! -f "$tmpdir/plank" ]; then
        err "extracted archive does not contain 'plank' binary"
    fi

    # Install binary
    mkdir -p "$PLANK_BIN_DIR"
    mv "$tmpdir/plank" "$PLANK_BIN_DIR/plank"
    chmod +x "$PLANK_BIN_DIR/plank"

    say "plank $version installed to $PLANK_BIN_DIR/plank"

    # Install documentation
    if [ -d "$tmpdir/book" ]; then
        mkdir -p "$(dirname "$PLANK_DOC_DIR")"
        rm -rf "$PLANK_DOC_DIR"
        mv "$tmpdir/book" "$PLANK_DOC_DIR"
        say "documentation installed to $PLANK_DOC_DIR"
    fi

    # VS Code extension install/update
    install_vscode_extension "$version" "$tmpdir"

    say "run 'plank --help' to get started"
}

editor_display_name() {
    case "$1" in
        *code)   echo "VS Code" ;;
        *cursor) echo "Cursor" ;;
        *codium) echo "VSCodium" ;;
        *)       echo "$1" ;;
    esac
}

resolve_editor_cmd() {
    local cmd="$1"
    if command -v "$cmd" > /dev/null 2>&1; then
        echo "$cmd"
        return
    fi
    # Fallback: find macOS .app bundles via Spotlight
    if [ "$PLATFORM" = "darwin" ] && command -v mdfind > /dev/null 2>&1; then
        local bundle_id=""
        case "$cmd" in
            code)   bundle_id="com.microsoft.VSCode" ;;
            cursor) bundle_id="com.todesktop.230313mzl4w4u92" ;;
            codium) bundle_id="com.vscodium" ;;
        esac
        if [ -n "$bundle_id" ]; then
            local app_dir
            app_dir=$(mdfind "kMDItemCFBundleIdentifier == '$bundle_id'" 2>/dev/null | head -1)
            if [ -n "$app_dir" ]; then
                local bin_path="$app_dir/Contents/Resources/app/bin/$cmd"
                if [ -x "$bin_path" ]; then
                    echo "$bin_path"
                    return
                fi
            fi
        fi
    fi
}

is_extension_installed() {
    local editor="$1"
    "$editor" --list-extensions 2>/dev/null | grep -qi "^plankevm$"
}

should_install_extension() {
    local editor="$1"
    local editor_name=$(editor_display_name "$editor")

    if is_extension_installed "$editor"; then
        say "updating Plank extension for $editor_name..."
        return 0
    fi

    printf "plankup: install Plank syntax highlighting for %s? [y/N] " "$editor_name"
    read -r answer
    if [ "$answer" = "y" ] || [ "$answer" = "Y" ]; then
        return 0
    fi
    return 1
}

install_vscode_extension() {
    local version="$1"
    local tmpdir="$2"
    local downloaded=false

    local vsix_name="plankevm-${version}.vsix"
    local vsix_url="$GITHUB_DOWNLOAD/$version/$vsix_name"

    for cmd in code cursor codium; do
        local resolved=$(resolve_editor_cmd "$cmd")
        if [ -z "$resolved" ]; then
            continue
        fi
        if ! should_install_extension "$resolved"; then
            continue
        fi

        local editor_name=$(editor_display_name "$resolved")

        if [ "$downloaded" = false ]; then
            download "$vsix_url" "$tmpdir/$vsix_name"
            downloaded=true
        fi

        "$resolved" --install-extension "$tmpdir/$vsix_name" --force > /dev/null 2>&1 \
            && say "Plank extension installed for $editor_name" \
            || warn "failed to install extension for $editor_name"
    done
}

main "$@"
