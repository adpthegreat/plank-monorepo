{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Plank",
  "scopeName": "source.plank",
  "patterns": [
    { "include": "#comments" },
    { "include": "#imports" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#strings" },
    { "include": "#literals" },
    { "include": "#functions" },
    { "include": "#identifiers" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.plank",
          "match": "//.*$"
        },
        {
          "name": "comment.block.plank",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "match": "\\b(import)\\s+([a-zA-Z_][a-zA-Z0-9_]*(?:::[a-zA-Z_][a-zA-Z0-9_]*)*)(?:::(\\*))?\\s*(?:(as)\\s+([a-zA-Z_][a-zA-Z0-9_]*))?",
          "captures": {
            "1": { "name": "keyword.other.import.plank" },
            "2": { "name": "entity.name.namespace.plank" },
            "3": { "name": "keyword.operator.glob.plank" },
            "4": { "name": "keyword.other.as.plank" },
            "5": { "name": "entity.name.type.plank" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.plank",
          "match": "\\b(if|else|while|return|inline)\\b"
        },
        {
          "name": "keyword.declaration.plank",
          "match": "\\b(const|let|mut|fn|struct|init|run)\\b"
        },
        {
          "name": "keyword.other.plank",
          "match": "\\b(import|as|comptime)\\b"
        },
        {
          "name": "keyword.operator.logical.plank",
          "match": "\\b(and|or)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.plank",
          "match": "\\b(u256|bool|void|memptr|type|function|never)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.plank",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.plank",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "literals": {
      "patterns": [
        {
          "name": "constant.language.boolean.plank",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.numeric.hex.plank",
          "match": "\\b0x[0-9A-Fa-f][0-9A-Fa-f_]*\\b"
        },
        {
          "name": "constant.numeric.binary.plank",
          "match": "\\b0b[01][01_]*\\b"
        },
        {
          "name": "constant.numeric.decimal.plank",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.plank" }
          }
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "match": "\\b(?:const)\\s+([A-Z][A-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "variable.other.constant.plank" }
          }
        },
        {
          "match": "\\b(?:let)\\s+(?:mut\\s+)?([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "variable.other.plank" }
          }
        },
        {
          "name": "variable.other.constant.plank",
          "match": "\\b[A-Z][A-Z0-9_]*\\b"
        },
        {
          "name": "variable.other.plank",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.plank",
          "match": "==|!=|<=|>=|<(?!/)|>(?!/)"
        },
        {
          "name": "keyword.operator.arithmetic.plank",
          "match": "\\+%|-%|\\*%|\\+/|-/|</|>/|\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.bitwise.plank",
          "match": "<<|>>|&|\\||\\^|~"
        },
        {
          "name": "keyword.operator.logical.plank",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.assignment.plank",
          "match": "="
        }
      ]
    }
  }
}
