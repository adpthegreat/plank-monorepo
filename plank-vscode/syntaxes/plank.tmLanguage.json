{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Plank",
  "scopeName": "source.plank",
  "patterns": [
    { "include": "#comments" },
    { "include": "#imports" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#strings" },
    { "include": "#literals" },
    { "include": "#builtins" },
    { "include": "#functions" },
    { "include": "#identifiers" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.plank",
          "match": "//.*$"
        },
        {
          "name": "comment.block.plank",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "begin": "\\b(import)\\b",
          "beginCaptures": {
            "1": { "name": "keyword.other.import.plank" }
          },
          "end": "(?=;|$)",
          "patterns": [
            {
              "match": "\\b(as)\\b",
              "name": "keyword.other.as.plank"
            },
            {
              "match": "\\*",
              "name": "keyword.operator.glob.plank"
            },
            {
              "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b",
              "name": "entity.name.namespace.plank"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.plank",
          "match": "\\b(if|else|while|return|inline)\\b"
        },
        {
          "name": "keyword.declaration.plank",
          "match": "\\b(const|let|mut|fn|struct|init|run)\\b"
        },
        {
          "name": "keyword.other.plank",
          "match": "\\b(import|as|comptime)\\b"
        },
        {
          "name": "keyword.operator.logical.plank",
          "match": "\\b(and|or)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.plank",
          "match": "\\b(u256|bool|void|memptr|type|function|never)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.plank",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.plank",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "literals": {
      "patterns": [
        {
          "name": "constant.language.boolean.plank",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.numeric.hex.plank",
          "match": "\\b0x[0-9A-Fa-f][0-9A-Fa-f_]*\\b"
        },
        {
          "name": "constant.numeric.binary.plank",
          "match": "\\b0b[01][01_]*\\b"
        },
        {
          "name": "constant.numeric.decimal.plank",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "comment": "EVM Arithmetic",
          "name": "support.function.builtin.plank",
          "match": "@(?:evm_add|evm_mul|evm_sub|evm_div|evm_sdiv|evm_mod|evm_smod|evm_addmod|evm_mulmod|evm_exp|evm_signextend)\\b"
        },
        {
          "comment": "EVM Comparison & Bitwise Logic",
          "name": "support.function.builtin.plank",
          "match": "@(?:evm_lt|evm_gt|evm_slt|evm_sgt|evm_eq|evm_iszero|evm_and|evm_or|evm_xor|evm_not|evm_byte|evm_shl|evm_shr|evm_sar)\\b"
        },
        {
          "comment": "EVM Keccak-256",
          "name": "support.function.builtin.plank",
          "match": "@evm_keccak256\\b"
        },
        {
          "comment": "EVM Environment Information",
          "name": "support.function.builtin.plank",
          "match": "@(?:evm_address_this|evm_balance|evm_origin|evm_caller|evm_callvalue|evm_calldataload|evm_calldatasize|evm_calldatacopy|evm_codesize|evm_codecopy|evm_gasprice|evm_extcodesize|evm_extcodecopy|evm_returndatasize|evm_returndatacopy|evm_extcodehash|evm_gas)\\b"
        },
        {
          "comment": "EVM Block Information",
          "name": "support.function.builtin.plank",
          "match": "@(?:evm_blockhash|evm_coinbase|evm_timestamp|evm_number|evm_difficulty|evm_gaslimit|evm_chainid|evm_selfbalance|evm_basefee|evm_blobhash|evm_blobbasefee)\\b"
        },
        {
          "comment": "EVM State Manipulation",
          "name": "support.function.builtin.plank",
          "match": "@(?:evm_sload|evm_sstore|evm_tload|evm_tstore)\\b"
        },
        {
          "comment": "EVM Logging Operations",
          "name": "support.function.builtin.plank",
          "match": "@evm_log[0-4]\\b"
        },
        {
          "comment": "EVM System Calls",
          "name": "support.function.builtin.plank",
          "match": "@(?:evm_create2?|evm_callcode|evm_delegatecall|evm_staticcall|evm_call|evm_return|evm_stop|evm_revert|evm_invalid|evm_selfdestruct)\\b"
        },
        {
          "comment": "IR Memory Primitives",
          "name": "support.function.builtin.plank",
          "match": "@(?:malloc_zeroed|malloc_uninit)\\b"
        },
        {
          "comment": "Memory Manipulation",
          "name": "support.function.builtin.plank",
          "match": "@(?:mcopy|mload(?:[1-9]|[12][0-9]|3[0-2])|mstore(?:[1-9]|[12][0-9]|3[0-2]))\\b"
        },
        {
          "comment": "Bytecode Introspection",
          "name": "support.function.builtin.plank",
          "match": "@(?:runtime_start_offset|init_end_offset|runtime_length)\\b"
        },
        {
          "comment": "Comptime Type Reflection",
          "name": "support.function.builtin.plank",
          "match": "@(?:is_struct|field_count|field_type|get_field|set_field)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.plank" }
          }
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "match": "\\b(?:const)\\s+([A-Z][A-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "variable.other.constant.plank" }
          }
        },
        {
          "match": "\\b(?:let)\\s+(?:mut\\s+)?([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "variable.other.plank" }
          }
        },
        {
          "name": "variable.other.constant.plank",
          "match": "\\b[A-Z][A-Z0-9_]*\\b"
        },
        {
          "name": "variable.other.plank",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.plank",
          "match": "==|!=|<=|>=|<(?!/)|>(?!/)"
        },
        {
          "name": "keyword.operator.arithmetic.plank",
          "match": "\\+%|-%|\\*%|\\+/|-/|</|>/|\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.bitwise.plank",
          "match": "<<|>>|&|\\||\\^|~"
        },
        {
          "name": "keyword.operator.logical.plank",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.assignment.plank",
          "match": "="
        }
      ]
    }
  }
}
